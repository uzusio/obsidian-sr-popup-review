{
  "name": "sr-popup-review",
  "version": "1.0.1",
  "description": "Review Spaced Repetition flashcards in a small always-on-top popup that appears at regular intervals",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs watch",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "spaced-repetition",
    "flashcards"
  ],
  "author": "uzusio",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.5",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "obsidian": "latest",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0"
  }
}
